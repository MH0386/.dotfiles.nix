{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "devenv": {
      "enabled": true,
      "type": "remote",
      "url": "mcp.devenv.sh"
    },
    "git": {
      "command": [
        "uvx",
        "mcp-server-git"
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer ${env:GH_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "nixos": {
      "command": [
        "uvx",
        "mcp-nixos"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "plugin": [
    "opencode-wakatime",
    "oh-my-opencode",
    "opencode-md-table-formatter",
    "opencode-skillful",
    "opencode-workspace",
    "opencode-worktree",
    "opencode-supermemory",
    "opencode-snip",
    "opencode-agent-memory"
  ],
  "share": "auto"
}